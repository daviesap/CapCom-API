rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /public/{filePath=**} {
      allow read: if true;
    }

    match /snapshots/{filePath=**} {
      allow read: if true;
    }

    match /logos/{filePath=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /protected/{app}/{eventId}/{filePath=**} {
      allow read: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in
          firestore.get(/databases/(default)/documents/allowedEmails/$(eventId)).data.allowedEmails;
    }
  }
}
